    <html lang="en">
      <head>
        <meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title >Widgets - Web Widget</title><style >web-widget{display:contents}</style><script type="module" src="/@vite/client"></script><script type="module" src="/entry.client.ts"></script><script type="server:context">{"pathname":"/examples/frameworks","params":{}}</script>
      </head>
      <body>
        <!--[--><a href="#main-content" class="skip-link"> Skip navigation, go to main content </a><header class="_header_408c0a"><div class="_headerContent_408c0a"><div class="_brandLogo_408c0a"><a class="_brandText_408c0a" href="/"> Web Widget </a><div class="_techStackBadge_408c0a"><span class="_techText_408c0a">Vue Example</span></div></div><nav class="_navigation_08e302" aria-label="Main navigation" role="navigation"><button class="_mobileMenuButton_08e302" aria-expanded="false" aria-controls="mobile-navigation-menu" aria-label="Open navigation menu"><span class="_hamburgerIcon_08e302"><span class="_hamburgerLine_08e302"></span><span class="_hamburgerLine_08e302"></span><span class="_hamburgerLine_08e302"></span></span></button><ul id="mobile-navigation-menu" class="_navigationMenu_08e302" role="list" aria-hidden="true"><!--[--><li role="listitem"><a href="/examples" class="" aria-label="Home">Home</a></li><li role="listitem"><a href="/examples/static" class="" aria-label="Static Page">Static Page</a></li><li role="listitem"><a href="/examples/params/web-widget" class="" aria-label="Dynamic Routing">Dynamic Routing</a></li><li role="listitem"><a href="/examples/fetch" class="" aria-label="Data Fetching">Data Fetching</a></li><li role="listitem"><a href="/examples/action" class="" aria-label="Server Actions">Server Actions</a></li><li role="listitem"><a href="/examples/frameworks" class="" aria-label="Widgets">Widgets</a></li><li role="listitem"><a href="/examples/middleware" class="" aria-label="Middleware">Middleware</a></li><!--]--></ul><!-- Mobile menu background overlay --><!----></nav></div></header><main id="main-content" class="_main_408c0a" tabindex="-1"><!--[--><div class="_container_b6e01e"><h1 class="_pageTitle_b6e01e">🍀 Widgets</h1><div class="_highlight_b6e01e _info_b6e01e"><h2>React and Vue components collaborate on the same page</h2><p> One of Web Widget&#39;s core features is supporting multiple frontend frameworks to coexist seamlessly in the same application. The following demo shows how React and Vue components can work together on the same page. </p></div><div class="_mb6_b6e01e"><h3 class="_sectionTitle_b6e01e">Framework Coexistence Demo</h3><div class="_grid_b6e01e _grid2_b6e01e"><div class="_card_b6e01e"><h4 class="_cardTitle_b6e01e">React Counter</h4><p class="_cardDescription_b6e01e"> Counter component implemented with React 19 and modern Hooks </p><div class="_mt3_b6e01e"><web-widget import="/routes/examples/(components)/Counter@widget.tsx" name="ReactCounter" loading="lazy" rendertarget="light" contextdata="{&quot;count&quot;:0,&quot;variant&quot;:&quot;react&quot;}" recovering><div class="_counter_a157b1" data-variant="react"><span class="_counterLabel_a157b1">React<!-- --> Counter</span><button class="_button_a157b1" aria-label="Decrease count"><span>−</span></button><span class="_count_a157b1" aria-label="Current count: 0">0</span><button class="_button_a157b1" aria-label="Increase count"><span>+</span></button></div></web-widget></div></div><div class="_card_b6e01e"><h4 class="_cardTitle_b6e01e">Vue Counter</h4><p class="_cardDescription_b6e01e"> Counter component implemented with Vue 3 Composition API </p><div class="_mt3_b6e01e"><web-widget import="/routes/examples/(components)/Counter@widget.vue" name="VueCounter" loading="lazy" rendertarget="light" contextdata="{&quot;count&quot;:0,&quot;variant&quot;:&quot;vue&quot;}" recovering><div class="counter" data-variant="vue" data-v-8f2b1605><span class="counterLabel" data-v-8f2b1605>Vue Counter </span><button class="button" aria-label="Decrease count" data-v-8f2b1605><span data-v-8f2b1605>−</span></button><span class="count" aria-label="Current count: 0" data-v-8f2b1605>0</span><button class="button" aria-label="Increase count" data-v-8f2b1605><span data-v-8f2b1605>+</span></button></div></web-widget></div></div></div></div><div class="_mb6_b6e01e"><h3 class="_sectionTitle_b6e01e">Technical Features</h3><div class="_grid_b6e01e _grid3_b6e01e"><div class="_card_b6e01e"><div class="_cardIcon_b6e01e">🔄</div><h4 class="_cardTitle_b6e01e">Interoperability</h4><p class="_cardDescription_b6e01e"> Components from different tech stacks can seamlessly integrate with each other through automatic conversion </p></div><div class="_card_b6e01e"><div class="_cardIcon_b6e01e">⚡</div><h4 class="_cardTitle_b6e01e">Isomorphic Rendering</h4><p class="_cardDescription_b6e01e"> Components from both frameworks support server-side rendering and client-side hydration </p></div><div class="_card_b6e01e"><div class="_cardIcon_b6e01e">🔒</div><h4 class="_cardTitle_b6e01e">Type Safe</h4><p class="_cardDescription_b6e01e"> TypeScript type definitions ensure type safety for cross-framework component calls </p></div></div></div></div><!--]--></main><footer class="_footer_408c0a"><div class="_footerContent_408c0a"><div class="_footerBrand_408c0a"><h3 class="_footerBrandName_408c0a">Web Widget</h3><p class="_footerTagline_408c0a"> Simplicity is the ultimate sophistication </p></div><div class="_footerLinks_408c0a"><a href="https://github.com/web-widget/web-widget#readme" target="_blank" rel="noopener noreferrer" class="_footerLink_408c0a"> 📚 Documentation </a><a href="https://github.com/web-widget/web-widget" target="_blank" rel="noopener noreferrer" class="_footerLink_408c0a"> ⭐ GitHub </a></div></div></footer><!--]-->
      </body>
    </html>"
`;

