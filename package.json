{
  "name": "root",
  "homepage": "https://github.com/web-widget/web-widget#readme",
  "version": "0.0.0",
  "author": {
    "name": "aui"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/web-widget/web-widget.git"
  },
  "bugs": {
    "url": "https://github.com/web-widget/web-widget/issues"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@eslint/eslintrc": "^3.3.6",
    "@eslint/js": "^9.39.5",
    "@internal/eslint-config": "workspace:*",
    "c8": "latest",
    "finepack": "latest",
    "git-authors-cli": "latest",
    "nano-staged": "latest",
    "prettier": "latest",
    "publint": "^0.3.17",
    "simple-git-hooks": "latest",
    "syncpack": "latest",
    "turbo": "latest",
    "unbuild": "^1.2.1"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "build": "pnpm run build:packages && pnpm run build:examples",
    "build:benchmarks": "turbo run build --filter=@benchmarks/*",
    "build:examples": "turbo run build --filter=@examples/* --force",
    "build:packages": "turbo run build --filter='./packages/*' --filter='./internal/*'",
    "build:playgrounds": "turbo run build --filter=@playgrounds/*",
    "changeset": "changeset add",
    "clean": "pnpm -r run clean && rm -rf ./node_modules",
    "clean:build": "pnpm -r run clean:build",
    "clean:node": "pnpm -r run clean:node",
    "contributors": "git-authors-cli && finepack",
    "coverage": "c8 report --reporter=lcov --reporter=text",
    "dev": "turbo run dev --filter=@playgrounds/router",
    "examples-catalog:check": "node scripts/materialize-examples-catalog.js --check",
    "examples-catalog:materialize": "node scripts/materialize-examples-catalog.js",
    "lint": "turbo run lint",
    "lockfile": "pnpm install --lockfile && git add pnpm-lock.yaml && git commit -m \"build: regenerate lock\"",
    "npm-trust:setup": "bash scripts/setup-npm-trusted-publishing.sh",
    "postinstall": "pnpm --filter @internal/eslint-config build && ./node_modules/.bin/simple-git-hooks",
    "prebuild": "pnpm -r run clean:build",
    "prettier": "prettier **/*.{ts,tsx,js,vue} --write",
    "publint": "node scripts/check-published-packages.js",
    "syncpack:json": "syncpack format --source '**/*package.json'",
    "test": "c8 --reporter=lcov --reporter=text turbo run test",
    "test:scripts": "node --test scripts/*.test.js",
    "test:smoke": "pnpm run build:examples",
    "typecheck": "pnpm -r --filter './packages/*' exec tsc --noEmit",
    "update": "pnpm -r exec ncu -- --upgrade && ncu -- --upgrade",
    "update:check": "pnpm -r exec ncu -- --errorLevel 2 && ncu -- --errorLevel 2",
    "version:prepare": "changeset version && pnpm install --no-frozen-lockfile",
    "version:publish": "node scripts/publish.js"
  },
  "private": true,
  "nano-staged": {
    "*.{ts,tsx,md,mdx,js,jsx}": [
      "prettier --write"
    ],
    "package.json": [
      "finepack"
    ]
  },
  "packageManager": "pnpm@11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a",
  "simple-git-hooks": {
    "post-merge": "node scripts/git-hooks/post-merge-maintenance.js",
    "pre-commit": "node scripts/git-hooks/pre-commit.js"
  },
  "type": "module"
}
