{
  "name": "@web-widget/html",
  "description": "HTML adapter",
  "version": "3.0.0-beta.0",
  "homepage": "https://github.com/web-widget/web-widget#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/web-widget/web-widget.git",
    "directory": "packages/html"
  },
  "bugs": {
    "url": "https://github.com/web-widget/web-widget/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@web-widget/helpers": "workspace:*",
    "@web-widget/web-widget": "workspace:*"
  },
  "devDependencies": {
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "exports": {
    ".": {
      "types": "./dist/html.d.ts",
      "development": "./src/index.ts",
      "default": "./dist/html.js"
    },
    "./runtime": {
      "types": "./dist/html.runtime.d.ts",
      "development": "./src/runtime.ts",
      "default": "./dist/html.runtime.js"
    }
  },
  "webWidget": {
    "version": "1.0.0",
    "name": "html",
    "extensions": [
      ".html.ts",
      ".html.js"
    ],
    "runtime": "./runtime"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/html.d.ts",
        "default": "./dist/html.js"
      },
      "./runtime": {
        "types": "./dist/html.runtime.d.ts",
        "default": "./dist/html.runtime.js"
      }
    }
  },
  "scripts": {
    "build": "pnpm exec tsup",
    "clean:build": "rm -rf dist",
    "clean:node": "rm -rf node_modules",
    "dev": "pnpm exec tsup --watch",
    "lint": "eslint src",
    "prebuild": "pnpm run clean:build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "sideEffects": false,
  "type": "module"
}
