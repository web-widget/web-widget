{
  "name": "@web-widget/html",
  "description": "HTML adapter",
  "version": "3.0.0-beta.3",
  "homepage": "https://github.com/web-widget/web-widget#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/web-widget/web-widget.git",
    "directory": "packages/html"
  },
  "bugs": {
    "url": "https://github.com/web-widget/web-widget/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@web-widget/helpers": "workspace:*",
    "@web-widget/schema": "workspace:*",
    "@web-widget/web-widget": "workspace:*",
    "magic-string": "^0.30.5"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "rolldown": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./transform": {
      "types": "./dist/transform.d.ts",
      "development": "./src/transform.ts",
      "default": "./dist/transform.js"
    },
    "./adapter": {
      "types": "./dist/adapter.d.ts",
      "development": "./src/adapter.ts",
      "default": "./dist/adapter.js"
    },
    "./vite-plugin": {
      "types": "./dist/vite-plugin.d.ts",
      "development": "./src/vite-plugin.ts",
      "default": "./dist/vite-plugin.js"
    }
  },
  "peerDependencies": {
    "vite": "catalog:"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./transform": {
        "types": "./dist/transform.d.ts",
        "default": "./dist/transform.js"
      },
      "./adapter": {
        "types": "./dist/adapter.d.ts",
        "default": "./dist/adapter.js"
      },
      "./vite-plugin": {
        "types": "./dist/vite-plugin.d.ts",
        "default": "./dist/vite-plugin.js"
      }
    }
  },
  "scripts": {
    "build": "rolldown -c && tsc -p tsconfig.build.json --emitDeclarationOnly --outDir dist",
    "clean:build": "rm -rf dist",
    "clean:node": "rm -rf node_modules",
    "dev": "rolldown -c --watch",
    "lint": "eslint src",
    "prebuild": "pnpm run clean:build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "sideEffects": false,
  "type": "module"
}
