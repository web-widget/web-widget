{
  "name": "@web-widget/preact",
  "description": "Preact adapter",
  "version": "3.0.0-beta.4",
  "homepage": "https://github.com/web-widget/web-widget#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/web-widget/web-widget.git",
    "directory": "packages/preact"
  },
  "bugs": {
    "url": "https://github.com/web-widget/web-widget/issues"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "dependencies": {
    "@web-widget/helpers": "workspace:*",
    "@web-widget/schema": "workspace:*",
    "@web-widget/web-widget": "workspace:*"
  },
  "peerDependencies": {
    "preact": "^10.0.0",
    "preact-render-to-string": "^6.0.0"
  },
  "devDependencies": {
    "happy-dom": "14.12.3",
    "preact": "catalog:",
    "preact-render-to-string": "^6.6.4",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "exports": {
    ".": {
      "types": "./dist/preact.d.ts",
      "development": "./src/index.ts",
      "default": "./dist/preact.js"
    },
    "./transform": {
      "types": "./dist/preact.transform.d.ts",
      "development": "./src/transform.ts",
      "default": "./dist/preact.transform.js"
    },
    "./adapter": {
      "worker": {
        "types": "./dist/preact.adapter.server.d.ts",
        "development": "./src/adapter.server.ts",
        "default": "./dist/preact.adapter.server.js"
      },
      "browser": {
        "types": "./dist/preact.adapter.client.d.ts",
        "development": "./src/adapter.client.ts",
        "default": "./dist/preact.adapter.client.js"
      },
      "default": {
        "types": "./dist/preact.adapter.server.d.ts",
        "development": "./src/adapter.server.ts",
        "default": "./dist/preact.adapter.server.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm exec tsup",
    "clean:build": "rm -rf dist",
    "clean:node": "rm -rf node_modules",
    "lint": "eslint src",
    "test": "vitest run"
  }
}
