{
  "name": "@web-widget/react",
  "description": "React adapter",
  "version": "3.0.0-beta.0",
  "homepage": "https://github.com/web-widget/web-widget#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/web-widget/web-widget.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/web-widget/web-widget/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@web-widget/helpers": "workspace:*",
    "@web-widget/schema": "workspace:*",
    "@web-widget/web-widget": "workspace:*"
  },
  "devDependencies": {
    "@types/jest": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "jest": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "ts-jest": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./runtime": {
      "worker": {
        "types": "./dist/react.server.d.ts",
        "development": "./src/server.ts",
        "default": "./dist/react.server.js"
      },
      "browser": {
        "types": "./dist/react.client.d.ts",
        "development": "./src/client.ts",
        "default": "./dist/react.client.js"
      },
      "default": {
        "types": "./dist/react.server.d.ts",
        "development": "./src/server.ts",
        "default": "./dist/react.server.js"
      }
    },
    "./globals": {
      "types": "./globals.d.ts"
    }
  },
  "webWidget": {
    "version": "1.0.0",
    "name": "react",
    "extensions": [
      ".tsx",
      ".jsx"
    ],
    "runtime": "./runtime"
  },
  "files": [
    "dist",
    "globals.d.ts"
  ],
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./runtime": {
        "worker": {
          "types": "./dist/react.server.d.ts",
          "default": "./dist/react.server.js"
        },
        "browser": {
          "types": "./dist/react.client.d.ts",
          "default": "./dist/react.client.js"
        },
        "default": {
          "types": "./dist/react.server.d.ts",
          "default": "./dist/react.server.js"
        }
      },
      "./globals": {
        "types": "./globals.d.ts"
      }
    }
  },
  "scripts": {
    "build": "pnpm exec tsup",
    "clean:build": "rm -rf dist",
    "clean:node": "rm -rf node_modules",
    "dev": "pnpm exec tsup --watch",
    "lint": "eslint src",
    "prebuild": "pnpm run clean:build",
    "test": "jest"
  },
  "type": "module"
}
