{
  "name": "@web-widget/vue",
  "description": "Vue adapter",
  "version": "3.0.0-beta.4",
  "homepage": "https://github.com/web-widget/web-widget#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/web-widget/web-widget.git",
    "directory": "packages/vue"
  },
  "bugs": {
    "url": "https://github.com/web-widget/web-widget/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@web-widget/helpers": "workspace:*",
    "@web-widget/web-widget": "workspace:*",
    "@web-widget/schema": "workspace:*",
    "@web-widget/react": "workspace:*"
  },
  "devDependencies": {
    "happy-dom": "14.12.3",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "vue": "^3.5.34"
  },
  "exports": {
    ".": {
      "types": "./dist/vue.d.ts",
      "development": "./src/index.ts",
      "default": "./dist/vue.js"
    },
    "./transform": {
      "types": "./dist/vue.transform.d.ts",
      "development": "./src/transform.ts",
      "default": "./dist/vue.transform.js"
    },
    "./adapter": {
      "worker": {
        "types": "./dist/vue.adapter.server.d.ts",
        "development": "./src/adapter.server.ts",
        "default": "./dist/vue.adapter.server.js"
      },
      "browser": {
        "types": "./dist/vue.adapter.client.d.ts",
        "development": "./src/adapter.client.ts",
        "default": "./dist/vue.adapter.client.js"
      },
      "default": {
        "types": "./dist/vue.adapter.server.d.ts",
        "development": "./src/adapter.server.ts",
        "default": "./dist/vue.adapter.server.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "vue": ">3.3.3"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/vue.d.ts",
        "default": "./dist/vue.js"
      },
      "./transform": {
        "types": "./dist/vue.transform.d.ts",
        "default": "./dist/vue.transform.js"
      },
      "./adapter": {
        "worker": {
          "types": "./dist/vue.adapter.server.d.ts",
          "default": "./dist/vue.adapter.server.js"
        },
        "browser": {
          "types": "./dist/vue.adapter.client.d.ts",
          "default": "./dist/vue.adapter.client.js"
        },
        "default": {
          "types": "./dist/vue.adapter.server.d.ts",
          "default": "./dist/vue.adapter.server.js"
        }
      }
    }
  },
  "scripts": {
    "build": "pnpm exec tsup",
    "clean:build": "rm -rf dist",
    "clean:node": "rm -rf node_modules",
    "dev": "pnpm exec tsup --watch",
    "lint": "eslint src",
    "prebuild": "pnpm run clean:build",
    "test": "vitest run"
  },
  "sideEffects": false,
  "type": "module"
}
