 target="" rel="" >Vue 2 host</a ></li><li><a href="/html-import-widgets" target="" rel="" >HTML host</a ></li><li class="menu-category">Integrations</li> <li><a href="/dynamic-routes/@web-widget" target="" rel="" >Dynamic routes</a ></li><li><a href="/custom-handlers" target="" rel="" >Custom handlers</a ></li><li><a href="/form" target="" rel="" >Forms</a ></li><li><a href="/background-tasks" target="" rel="" >Background tasks</a ></li><li><a href="/server-action" target="" rel="" >Server actions</a ></li><li><a href="/meta" target="" rel="" >Document metadata</a ></li><li><a href="/vue3-router" target="" rel="" >Vue Router 4</a ></li><li><a href="/vue2-router" target="" rel="" >Vue Router 3</a ></li><li><a href="/api/hello-world" target="_blank" rel="noopener" >API route</a ></li><li class="menu-category">Other</li> <li><a href="/vue-module-css" target="" rel="" >Vue CSS Modules</a ></li> </ul></nav></web-widget></aside><main><header class="ds-page-header"><h1>Meta</h1><p class="ds-description">Set document head metadata - such as title and description - per route. Check the page source to see the meta tags.</p></header><section class="ds-section"><h2>JSON</h2><pre class="ds-code-block">{
  &quot;style&quot;: [
    {
      &quot;content&quot;: &quot;web-widget{display:contents}&quot;
    }
  ],
  &quot;script&quot;: [
    {
      &quot;type&quot;: &quot;module&quot;,
      &quot;src&quot;: &quot;/@vite/client&quot;
    },
    {
      &quot;type&quot;: &quot;module&quot;,
      &quot;src&quot;: &quot;/entry.client.ts&quot;
    },
    {
      &quot;type&quot;: &quot;server:context&quot;,
      &quot;content&quot;: &quot;{\\&quot;pathname\\&quot;:\\&quot;/meta\\&quot;,\\&quot;params\\&quot;:{}}&quot;
    }
  ],
  &quot;lang&quot;: &quot;en&quot;,
  &quot;meta&quot;: [
    {
      &quot;charset&quot;: &quot;utf-8&quot;
    },
    {
      &quot;name&quot;: &quot;viewport&quot;,
      &quot;content&quot;: &quot;width=device-width, initial-scale=1.0&quot;
    },
    {
      &quot;name&quot;: &quot;keywords&quot;,
      &quot;content&quot;: &quot;c, d&quot;
    },
    {
      &quot;property&quot;: &quot;og:title&quot;,
      &quot;content&quot;: &quot;New Site&quot;
    },
    {
      &quot;property&quot;: &quot;og:url&quot;,
      &quot;content&quot;: &quot;http://newsblog.org/news/136756249803614&quot;
    },
    {
