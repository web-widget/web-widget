"<!doctype html><html lang="en"><head> <meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title>😄New title!</title><meta name="description" content="HTML Meta Data Example" /><meta name="keywords" content="c, d" /><meta property="og:title" content="New Site" /><meta property="og:url" content="http://newsblog.org/news/136756249803614" /><meta name="hello" content="world" /><link type="application/json" href="https://google.com/test.json" /><style>web-widget{display:contents}</style><script type="module" src="/@vite/client"></script><script type="module" src="/entry.client.ts"></script><script type="server:context">{"pathname":"/meta","params":{}}</script> </head><body> <header class="site-header"><h1>Web Router Playground</h1></header><div class="container"><aside data-playground-menu="true"><web-widget id="wo"><nav aria-label="Playground examples"><ul class="menu"><li class="menu-home"><a href="/">Home</a></li> <li class="menu-category">Frameworks</li> <li><a href="/frameworks" target="" rel="" >Capability overview</a ></li><li><a href="/frameworks/react" target="" rel="" >React</a ></li><li><a href="/frameworks/html" target="" rel="" >HTML</a ></li><li><a href="/frameworks/vue3" target="" rel="" >Vue 3</a ></li><li><a href="/frameworks/vue2" target="" rel="" >Vue 2</a ></li><li><a href="/frameworks/svelte" target="" rel="" >Svelte</a ></li><li><a href="/frameworks/solid" target="" rel="" >Solid</a ></li><li><a href="/frameworks/preact" target="" rel="" >Preact</a ></li><li class="menu-category">Streaming</li> <li><a href="/streaming/react" target="" rel="" >React</a ></li><li><a href="/streaming/vue3" target="" rel="" >Vue 3</a ></li><li><a href="/streaming/html" target="" rel="" >HTML</a ></li><li><a href="/streaming/solid" target="" rel="" >Solid</a ></li><li><a href="/streaming/preact" target="" rel="" >Preact</a ></li><li><a href="/streaming/html/suspense" target="" rel="" >HTML suspense</a ></li><li><a href="/strea